<?xml version="1.0" encoding="utf-8"?>
<!-- Glassmorphism card: translucent dark surface with soft rounded corners.
     Used for elevated containers like the Radio Hub dashboard and feed cards. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/glass_surface_60" />
    <corners android:radius="20dp" />
    <stroke
        android:width="1dp"
        android:color="@color/glass_highlight_5" />
</shape>
