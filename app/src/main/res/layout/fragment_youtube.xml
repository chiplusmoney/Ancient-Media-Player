<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <player.music.ancient.views.insets.InsetsRecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingTop="8dp"
            android:paddingBottom="88dp"
            android:visibility="gone"
            tools:listitem="@layout/item_youtube_feed" />

        <!-- Unified state container — handles loading, error, and empty -->
        <LinearLayout
            android:id="@+id/stateContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingHorizontal="32dp"
            android:paddingBottom="88dp"
            android:visibility="gone">

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/stateProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                app:indicatorColor="@color/aether_primary"
                app:trackColor="@color/aether_surface_container_high" />

            <ImageView
                android:id="@+id/stateIcon"
                android:layout_width="100dp"
                android:layout_height="100dp"
                android:layout_marginTop="24dp"
                android:alpha="0.4"
                android:importantForAccessibility="no"
                android:visibility="gone"
                app:tint="@color/aether_on_surface_variant"
                tools:src="@drawable/ic_youtube"
                tools:visibility="visible" />

            <TextView
                android:id="@+id/stateTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/manrope"
                android:gravity="center"
                android:textColor="@color/aether_on_surface"
                android:textSize="20sp"
                android:textStyle="bold"
                tools:text="Loading Feed" />

            <TextView
                android:id="@+id/stateMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:textColor="@color/aether_on_surface_variant"
                android:textSize="14sp"
                tools:text="Fetching the latest videos from your channels..." />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/stateActionButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:backgroundTint="@color/aether_primary"
                android:fontFamily="@font/manrope"
                android:textColor="@color/aether_on_primary"
                android:visibility="gone"
                tools:text="Retry"
                tools:visibility="visible" />
        </LinearLayout>
    </FrameLayout>

    <player.music.ancient.views.TopAppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/refreshProgress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/aether_primary"
        app:layout_anchor="@id/appBarLayout"
        app:layout_anchorGravity="bottom"
        app:trackColor="@color/aether_surface_container" />

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addChannelFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="110dp"
        android:backgroundTint="@color/aether_primary"
        android:contentDescription="Add YouTube Channel"
        app:srcCompat="@drawable/ic_add"
        app:tint="@color/aether_on_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
