<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="24dp"
    android:background="?android:attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true">

    <!-- Thumbnail container with rounded corners -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/thumbnailContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:cardBackgroundColor="@color/aether_surface_container"
        app:cardCornerRadius="16dp"
        app:cardElevation="0dp"
        app:layout_constraintDimensionRatio="16:9"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/videoThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:importantForAccessibility="no"
            android:scaleType="centerCrop"
            tools:src="@drawable/default_audio_art" />

        <!-- Bottom gradient for readability -->
        <View
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="bottom"
            android:background="@drawable/aether_feed_thumbnail_overlay" />

        <!-- Timestamp badge -->
        <TextView
            android:id="@+id/publishedDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="10dp"
            android:background="@drawable/rounded_black_bg"
            android:fontFamily="@font/manrope"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold"
            tools:text="2 days ago" />

    </com.google.android.material.card.MaterialCardView>

    <!-- Channel avatar -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/channelAvatar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_marginTop="12dp"
        android:scaleType="centerCrop"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/thumbnailContainer"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Circle"
        app:strokeColor="@color/aether_outline_variant"
        app:strokeWidth="1dp"
        tools:src="@drawable/ic_youtube" />

    <!-- Video title — Manrope bold, white on dark -->
    <TextView
        android:id="@+id/videoTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:fontFamily="@font/manrope"
        android:maxLines="2"
        android:textColor="@color/aether_on_surface"
        android:textSize="15sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/channelAvatar"
        app:layout_constraintTop_toBottomOf="@id/thumbnailContainer"
        tools:text="Awesome Video Title Goes Here and Spans Two Lines" />

    <!-- Channel name — subdued per Sonic Aurora rules -->
    <TextView
        android:id="@+id/channelName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="3dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/aether_on_surface_variant"
        android:textSize="13sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/videoTitle"
        app:layout_constraintTop_toBottomOf="@id/videoTitle"
        tools:text="Channel Name • 1M views" />

</androidx.constraintlayout.widget.ConstraintLayout>
