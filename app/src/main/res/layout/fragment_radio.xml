<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayoutContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <player.music.ancient.views.TopAppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fitsSystemWindows="true" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ══════════════════════════════════════════════════ -->
            <!-- Premium Radio Hub — Now Playing Dashboard         -->
            <!-- Glassmorphism card with station artwork + metadata -->
            <!-- ══════════════════════════════════════════════════ -->
            <FrameLayout
                android:id="@+id/radioHubDashboard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="8dp"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground">

                <!-- Blurred background artwork (alpha-faded) -->
                <ImageView
                    android:id="@+id/hubBackgroundImage"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/radio_hub_expanded_height"
                    android:alpha="0.25"
                    android:importantForAccessibility="no"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/default_audio_art" />

                <!-- Glass overlay on top of the blurred artwork -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/radio_hub_expanded_height"
                    android:background="@drawable/aether_glass_card" />

                <!-- Content layer -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Header row: metadata + toggle -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/manrope"
                                android:letterSpacing="0.08"
                                android:text="@string/radio_now_playing"
                                android:textAllCaps="true"
                                android:textColor="@color/aether_on_surface_variant"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/hubStationName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:fontFamily="@font/manrope"
                                android:textColor="@color/aether_on_surface"
                                android:textSize="22sp"
                                android:textStyle="bold"
                                tools:text="102.5 FM Live" />

                            <TextView
                                android:id="@+id/hubLiveIndicator"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/aether_live_badge"
                                android:fontFamily="@font/manrope"
                                android:letterSpacing="0.06"
                                android:paddingHorizontal="14dp"
                                android:paddingVertical="4dp"
                                android:text="LIVE"
                                android:textColor="@color/aether_on_primary"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:visibility="gone"
                                tools:visibility="visible" />
                        </LinearLayout>

                        <ImageButton
                            android:id="@+id/dashboardToggleButton"
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:contentDescription="@string/radio_toggle_dashboard"
                            android:src="@drawable/ic_keyboard_arrow_up"
                            app:tint="@color/aether_on_surface_variant" />
                    </LinearLayout>

                    <!-- Expanded content: circular station artwork -->
                    <LinearLayout
                        android:id="@+id/hubExpandedContent"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:gravity="center"
                        android:orientation="vertical">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/hubStationArt"
                            android:layout_width="120dp"
                            android:layout_height="120dp"
                            android:scaleType="centerCrop"
                            app:shapeAppearanceOverlay="@style/circleImageView"
                            app:strokeColor="@color/aether_primary_dim"
                            app:strokeWidth="2dp"
                            tools:src="@drawable/ic_radio" />
                    </LinearLayout>

                </LinearLayout>
            </FrameLayout>

            <!-- Section header -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/manrope"
                android:text="Available Stations"
                android:textColor="@color/aether_on_surface"
                android:textSize="18sp"
                android:textStyle="bold" />

            <player.music.ancient.views.insets.InsetsRecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:nestedScrollingEnabled="false"
                android:paddingBottom="88dp"
                tools:listitem="@layout/item_radio_station" />

            <include
                android:id="@+id/emptyState"
                layout="@layout/view_radio_empty_state"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:visibility="gone" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/addStationFab"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="110dp"
        android:backgroundTint="@color/aether_primary"
        android:contentDescription="Add Radio Station"
        app:srcCompat="@drawable/ic_add"
        app:tint="@color/aether_on_primary" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
